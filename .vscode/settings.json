{
  "files.eol": "\n",
  // 解释器位置
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv",
  // 指定需要Cursorpyright排除分析的目录或文件路径
  // 作用：在已包含的路径中排除特定内容，优先级高于include配置（即排除规则会覆盖包含规则）
  // 特殊说明：若被排除的文件被未排除的源文件引用（导入），则仍可能被纳入分析
  // 路径规则：
  // - 支持具体路径（如["tests/"]）和通配符：
  //   * **：匹配任意层级目录（如["** /temp/"]排除所有层级的temp目录）
  //   * *：匹配零个或多个字符（如["*.log"]排除所有日志文件）
  //   * ?：匹配单个字符（如["debug?.py"]排除debug1.py、debugA.py等）
  // 默认排除项：若为空数组[]，则自动排除以下内容：
  //   **/node_modules、**/__pycache__、.git目录及所有虚拟环境目录
  // 使用场景：
  // - 排除临时文件、日志目录、第三方依赖等无需检查的内容
  // - 过滤测试代码、示例代码，仅关注核心业务代码
  // - 减少分析范围，提升大型项目的类型检查性能
  "cursorpyright.analysis.exclude": ["**/node_modules", "**/__pycache__", "**/.ipynb_checkpoints", "**/.pytest_cache", "**/.git", "**/.idea"],
  // 关闭默认的单元测试-unittest
  "python.testing.unittestEnabled": false,
  // 使用单元测试-pytest
  "python.testing.pytestEnabled": true,
  // 配置测试目录（workspace根目录，pytest会自动发现所有tests）
  "python.testing.cwd": "${workspaceFolder}",
  // 配置单元测试参数
  "python.testing.pytestArgs": ["--no-header", "--no-summary", "--capture=no", "-v", "-s", "-q"],
  // 在保存时自动发现和运行测试
  "python.testing.autoTestDiscoverOnSaveEnabled": false,
  // i18n-ally插件 - 启用框架: vue
  "i18n-ally.enabledFrameworks": ["vue"],
  // i18n-ally插件 - 本地化资源路径: web/src/locale
  "i18n-ally.localesPaths": ["web/src/locale"],
  // i18n-ally插件 - 资源解析器启用: ts
  "i18n-ally.enabledParsers": ["ts"],
  // i18n-ally插件 - 键样式: 嵌套
  "i18n-ally.keystyle": "nested",
  // ESLint - 格式化: 开启
  "eslint.format.enable": true,
  // ESLint - 工作目录
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],
  // Prettier - 配置文件路径
  "prettier.configPath": "./web/.prettierrc.json",
  // Ruff扩展设置
  "ruff.enable": true,
  "ruff.organizeImports": true,
  "ruff.fixAll": true,
  "ruff.importStrategy": "fromEnvironment",
  "ruff.path": ["uv", "run", "ruff"],
  "ruff.configuration": "${workspaceFolder}/.ruff.toml",
  // Even Better TOML 插件配置
  "evenBetterToml.formatter.alignEntries": true,
  "evenBetterToml.formatter.alignComments": true,
  "evenBetterToml.formatter.arrayTrailingComma": true,
  "evenBetterToml.formatter.arrayAutoExpand": true,
  "evenBetterToml.formatter.arrayAutoCollapse": true,
  "evenBetterToml.formatter.compactArrays": true,
  "evenBetterToml.formatter.compactInlineTables": true,
  "evenBetterToml.formatter.compactEntries": false,
  "evenBetterToml.formatter.columnWidth": 80,
  "evenBetterToml.formatter.indentTables": false,
  "evenBetterToml.formatter.indentEntries": false,
  "evenBetterToml.formatter.indentString": "  ",
  "evenBetterToml.formatter.reorderKeys": false,
  "evenBetterToml.formatter.allowedBlankLines": 2,
  "evenBetterToml.formatter.trailingNewline": true,
  "evenBetterToml.formatter.crlf": false,
  // Tailwind CSS - 类函数
  "tailwindCSS.classFunctions": ["cva", "cx"],
  // 启用保存时的代码操作
  "editor.formatOnSave": true,
  "oxc.fixKind": "all",
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.organizeImports.ruff": "explicit",
      "source.fixAll.ruff": "explicit",
      "source.removeUnusedImports": "explicit"
    }
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.action.useSortedInterfaceMembers.biome": "explicit",
      "source.action.noDuplicateClasses.biome": "explicit",
      "source.action.useSortedAttributes.biome": "explicit",
      "source.action.useSortedProperties.biome": "explicit",
      "source.action.useSortedKeys.biome": "explicit",
      "source.organizeImports.biome": "explicit",
      "source.fixAll.biome": "explicit",
      "source.removeUnusedImports": "explicit"
    }
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.action.useSortedInterfaceMembers.biome": "explicit",
      "source.action.noDuplicateClasses.biome": "explicit",
      "source.action.useSortedAttributes.biome": "explicit",
      "source.action.useSortedProperties.biome": "explicit",
      "source.action.useSortedKeys.biome": "explicit",
      "source.organizeImports.biome": "explicit",
      "source.fixAll.biome": "explicit",
      "source.removeUnusedImports": "explicit"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.action.useSortedInterfaceMembers.biome": "explicit",
      "source.action.noDuplicateClasses.biome": "explicit",
      "source.action.useSortedAttributes.biome": "explicit",
      "source.action.useSortedProperties.biome": "explicit",
      "source.action.useSortedKeys.biome": "explicit",
      "source.organizeImports.biome": "explicit",
      "source.fixAll.biome": "explicit",
      "source.removeUnusedImports": "explicit"
    }
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "explicit"
    }
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "explicit"
    }
  },
  "[html]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "explicit"
    }
  },
  "[vue]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.codeActionsOnSave": {
      "source.format.oxc": "always",
      "source.fixAll.oxc": "always"
    }
  },
  "[css]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "explicit"
    }
  },
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit"
    }
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit"
    }
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml",
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit"
    }
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "Dockerfile": "Dockerfile-*, .dockerignore, docker-entrypoint.sh",
    "pyproject.toml": "uv.lock, pyrightconfig.json, pytest.ini, alembic.ini, .pre-commit-config.yaml, .ruff.toml, .cz.toml",
    "tsconfig.json": "tsconfig.*.json, env.d.ts, typed-router.d.ts",
    "vite.config.*": "jsconfig*, vitest.config.*, cypress.config.*, playwright.config.*",
    "package.json": "package-lock.json, pnpm*, .yarnrc*, yarn*, .eslint*, eslint*, .oxlint*, oxlint*, .oxfmt*, .prettier*, prettier*, .editorconfig, biome.jsonc",
    "AI编程及智能体开发教案大纲.md": "Day*.md"
  },
  "python.languageServer": "None"
}
