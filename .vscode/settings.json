{
  "files.eol": "\n",
  // Claude Code MCP Servers
  "claude-code.mcpServers": {
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": ["serve", "--mcp"]
    }
  },
  // OpenAI Codex MCP Servers
  "codex.mcpServers": {
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": ["serve", "--mcp"]
    }
  },
  // 解释器位置
  "python.defaultInterpreterPath": "${workspaceFolder}/server/python/.venv",
  // 关闭默认的单元测试-unittest
  "python.testing.unittestEnabled": false,
  // 使用单元测试-pytest
  "python.testing.pytestEnabled": true,
  // 配置测试工作目录（Python 子项目，确保加载 pytest.ini）
  "python.testing.cwd": "${workspaceFolder}/server/python",
  // 配置单元测试参数
  "python.testing.pytestArgs": ["--no-header", "--no-summary", "--capture=no", "-v", "-s", "-q"],
  // 在保存时自动发现和运行测试
  "python.testing.autoTestDiscoverOnSaveEnabled": false,
  // i18n-ally插件 - 启用框架: vue
  "i18n-ally.enabledFrameworks": ["vue"],
  // i18n-ally插件 - 本地化资源路径: web/src/locale
  "i18n-ally.localesPaths": ["web/src/locale"],
  // i18n-ally插件 - 资源解析器启用: ts
  "i18n-ally.enabledParsers": ["ts"],
  // i18n-ally插件 - 键样式: 嵌套
  "i18n-ally.keystyle": "nested",
  // ESLint - 格式化: 开启
  "eslint.format.enable": true,
  // ESLint - 工作目录
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],
  // Prettier - 配置文件路径
  "prettier.configPath": "./web/.prettierrc.json",
  // Ruff扩展设置
  "ruff.enable": true,
  "ruff.organizeImports": true,
  "ruff.fixAll": true,
  "ruff.importStrategy": "fromEnvironment",
  "ruff.path": ["uv", "run", "ruff"],
  "ruff.configuration": "${workspaceFolder}/.ruff.toml",
  // Even Better TOML 插件配置
  "evenBetterToml.formatter.alignEntries": true,
  "evenBetterToml.formatter.alignComments": true,
  "evenBetterToml.formatter.arrayTrailingComma": true,
  "evenBetterToml.formatter.arrayAutoExpand": true,
  "evenBetterToml.formatter.arrayAutoCollapse": true,
  "evenBetterToml.formatter.compactArrays": true,
  "evenBetterToml.formatter.compactInlineTables": true,
  "evenBetterToml.formatter.compactEntries": false,
  "evenBetterToml.formatter.columnWidth": 80,
  "evenBetterToml.formatter.indentTables": false,
  "evenBetterToml.formatter.indentEntries": false,
  "evenBetterToml.formatter.indentString": "  ",
  "evenBetterToml.formatter.reorderKeys": false,
  "evenBetterToml.formatter.allowedBlankLines": 2,
  "evenBetterToml.formatter.trailingNewline": true,
  "evenBetterToml.formatter.crlf": false,
  // Tailwind CSS - 类函数
  "tailwindCSS.classFunctions": ["cva", "cx"],
  // 启用保存时的代码操作
  "editor.formatOnSave": true,
  "oxc.fixKind": "all",
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.organizeImports.ruff": "explicit",
      "source.fixAll.ruff": "explicit",
      "source.removeUnusedImports": "explicit"
    }
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.action.useSortedInterfaceMembers.biome": "explicit",
      "source.action.noDuplicateClasses.biome": "explicit",
      "source.action.useSortedAttributes.biome": "explicit",
      "source.action.useSortedProperties.biome": "explicit",
      "source.action.useSortedKeys.biome": "explicit",
      "source.organizeImports.biome": "explicit",
      "source.fixAll.biome": "explicit",
      "source.removeUnusedImports": "explicit"
    }
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.action.useSortedInterfaceMembers.biome": "explicit",
      "source.action.noDuplicateClasses.biome": "explicit",
      "source.action.useSortedAttributes.biome": "explicit",
      "source.action.useSortedProperties.biome": "explicit",
      "source.action.useSortedKeys.biome": "explicit",
      "source.organizeImports.biome": "explicit",
      "source.fixAll.biome": "explicit",
      "source.removeUnusedImports": "explicit"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.action.useSortedInterfaceMembers.biome": "explicit",
      "source.action.noDuplicateClasses.biome": "explicit",
      "source.action.useSortedAttributes.biome": "explicit",
      "source.action.useSortedProperties.biome": "explicit",
      "source.action.useSortedKeys.biome": "explicit",
      "source.organizeImports.biome": "explicit",
      "source.fixAll.biome": "explicit",
      "source.removeUnusedImports": "explicit"
    }
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "explicit"
    }
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "explicit"
    }
  },
  "[html]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "explicit"
    }
  },
  "[vue]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.codeActionsOnSave": {
      "source.format.oxc": "always",
      "source.fixAll.oxc": "always"
    }
  },
  "[css]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "explicit"
    }
  },
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit"
    }
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit"
    }
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml",
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit"
    }
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    ".gitignore": ".*ignore, .gitattributes, .markdownlint.json",
    ".mcp.json": ".mcp*",
    "Dockerfile": "Dockerfile-*, .dockerignore, docker-entrypoint.sh, nginx.conf, .env*, index.html",
    "pyproject.toml": "uv.lock, pyrightconfig.json, pytest.ini, alembic.ini, .pre-commit-config.yaml, .ruff.toml, .cz.toml, .python-version",
    "package.json": "package-lock.json, pnpm*, yarn*, .eslint*, .oxlint*, oxlint*, .oxfmt*, .prettier*, prettier*, .editorconfig, biome.jsonc, , tsconfig*, env.d.ts, typed-router.d.ts, components.json",
    "vite.config.*": "jsconfig*, vitest.config.*, cypress.config.*, playwright.config.*, .env.*",
    "Cargo.toml": "rust-toolchain.toml, rustfmt.toml, .nextest.toml",
    "README.md": "README*",
    "AI编程及智能体开发教案大纲.md": "Day*.md"
  },
  // 开启类型提示、自动导入，和Pylance一致
  "cursorpyright.analysis.diagnosticMode": "workspace",
  "cursorpyright.analysis.typeCheckingMode": "basic",
  "cursorpyright.analysis.autoImportCompletions": true,
  "cursorpyright.analysis.useLibraryCodeForTypes": true,
  "cursorpyright.analysis.extraPaths": ["server/python/src"],
  "cursorpyright.analysis.include": ["server/python/src"],
  "cursorpyright.analysis.exclude": [
    "tests",
    "**/ai_plugin",
    "**/ai/components/model",
    "**/ai/components/plugin",
    "**/ai/components/graphrag",
    "**/ai/components/datasource",
    "**/dist",
    "**/.venv",
    "**/.git",
    "**/*.md",
    "**/__pycache__",
    "**/.pytest_cache",
    "**/.ruff_cache",
    "**/.benchmarks",
    "**/node_modules",
    "**/migrations/**",
    "**/.ipynb_checkpoints"
  ],
  // Python 类型检查诊断配置（按类型分类）
  "cursorpyright.analysis.diagnosticSeverityOverrides": {
    // === 错误级别（必须修复） ===
    "reportUndefinedVariable": "error",
    "reportMissingImports": "error",

    // === 未使用代码 ===
    "reportUnusedFunction": "none",
    "reportUnusedVariable": "none",
    "reportUnusedParameter": "none",
    "reportUnusedCallResult": "none",
    "reportUnusedCoroutine": "none",
    "reportUnusedImport": "none",

    // === 类型推断 ===
    "reportUnknownVariableType": "none",
    "reportUnknownParameterType": "none",
    "reportUnknownArgumentType": "none",
    "reportUnknownMemberType": "none",
    "reportMissingTypeArgument": "none",
    "reportMissingParameterType": "none",
    "reportExplicitAny": "none",
    "reportAny": "none",
    "reportGeneralTypeIssues": "none",
    "reportMissingTypeStubs": "none",
    "reportInvalidTypeForm": "none",
    "reportUnannotatedClassAttribute": "none",

    // === 可选类型/空值 ===
    "reportOptionalMemberAccess": "none",
    "reportOptionalSubscript": "none",
    "reportOptionalIterable": "none",

    // === 类型操作 ===
    "reportAssignmentType": "none",
    "reportReturnType": "none",
    "reportArgumentType": "none",
    "reportIndexIssue": "none",
    "reportOperatorIssue": "none",
    "reportCallIssue": "none",
    "reportAttributeAccessIssue": "none",

    // === 类型兼容/覆盖 ===
    "reportIncompatibleMethodOverride": "none",
    "reportIncompatibleVariableOverride": "none",
    "reportImplicitOverride": "none",

    // === 不必要的代码 ===
    "reportUnnecessaryIsInstance": "none",
    "reportUnnecessaryComparison": "none",
    "reportUnnecessaryContains": "none",

    // === 变量相关 ===
    "reportPossiblyUnboundVariable": "none",
    "reportUninitializedInstanceVariable": "none",

    // === 类/装饰器 ===
    "reportUntypedClassDecorator": "none",
    "reportImplicitAbstractClass": "none",
    "reportOverlappingOverload": "none",

    // === 导入相关 ===
    "reportImportCycles": "none",

    // === 其他 ===
    "deprecateTypingAliases": "none",
    "reportImplicitStringConcatenation": "none"
  },
  // 调试配套（保留微软Python调试器）
  "python.debugger.type": "debugpy"
}
