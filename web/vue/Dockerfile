# Multi-module Dockerfile for Vue Frontend
# Supports BUILD_MODULES argument for selective module packaging
# Uses Alibaba Cloud mirror for faster pulls in China

ARG NODE_VERSION=22
FROM registry.cn-zhangjiakou.aliyuncs.com/kcloudy-images/node:${NODE_VERSION}-bookworm-slim AS builder

# Set working directory
WORKDIR /app

# Install pnpm
RUN corepack enable && corepack prepare pnpm@10.0.0 --activate && \
    pnpm config set registry https://registry.npmmirror.com

# Copy package files first for better cache
COPY package.json pnpm-lock.yaml ./

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy source code
COPY . .

# Build argument: comma-separated module names (default: all modules)
# Example: BUILD_MODULES=demo,iam,tenant (platform version)
# Example: BUILD_MODULES=demo (demo module only)
ARG BUILD_MODULES=demo,iam,tenant

# Generate modules config file (use sed for sh compatibility)
RUN echo "// Auto-generated by Docker build" > src/config/modules.ts && \
    echo "// BUILD_MODULES: ${BUILD_MODULES}" >> src/config/modules.ts && \
    echo "export const ENABLED_MODULES = ['$(echo ${BUILD_MODULES} | sed 's/,/','/')'] as const;" >> src/config/modules.ts && \
    echo "export type EnabledModule = typeof ENABLED_MODULES[number];" >> src/config/modules.ts

# Build the application
RUN pnpm build

# Production stage
FROM registry.cn-zhangjiakou.aliyuncs.com/kcloudy-images/nginx:alpine

# Install curl for health checks
RUN sed -i 's|https://dl-cdn.alpinelinux.org/alpine|https://mirrors.aliyun.com/alpine|g' /etc/apk/repositories && \
    apk add --no-cache curl

# Copy built assets from builder
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy nginx configuration
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Expose port
EXPOSE 80

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD curl -f http://localhost/health || exit 1

# Start nginx
CMD ["nginx", "-g", "daemon off;"]