# Multi-module Dockerfile for Vue Frontend
# Supports BUILD_MODULES argument for selective module packaging

ARG NODE_VERSION=22
FROM node:${NODE_VERSION}-alpine AS builder

# Set working directory
WORKDIR /app

# Install pnpm
RUN corepack enable && corepack prepare pnpm@10.0.0 --activate

# Copy package files first for better cache
COPY package.json pnpm-lock.yaml ./

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy source code
COPY . .

# Build argument: comma-separated module names (default: all modules)
# Example: BUILD_MODULES=demo,iam,tenant (platform version)
# Example: BUILD_MODULES=demo (demo module only)
ARG BUILD_MODULES=demo,iam,tenant

# Generate modules config file
RUN echo "// Auto-generated by Docker build\n\
// BUILD_MODULES: ${BUILD_MODULES}\n\
export const ENABLED_MODULES = ['${BUILD_MODULES//,/','}'] as const;\n\
export type EnabledModule = typeof ENABLED_MODULES[number];\n" > src/config/modules.ts

# Build the application
RUN pnpm build

# Production stage
FROM nginx:alpine

# Install curl for health checks
RUN apk add --no-cache curl

# Copy built assets from builder
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy nginx configuration
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Expose port
EXPOSE 80

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD curl -f http://localhost/health || exit 1

# Start nginx
CMD ["nginx", "-g", "daemon off;"]
