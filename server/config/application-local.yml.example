  # 落库加密
  db-in:
    # 是否启用
    enabled: true
    use: "db-in"
  # 前端输入加密
  web-in:
    # 是否启用
    enabled: true
    use: "web-in"
  # 前端输出解密
  web-out:
    # 临时密钥有效期（秒）
    temp-key-ttl: 300

# 代码沙箱环境地址
code-sandbox:
  endpoint: https://localhost:8081
  api-key: ""
  connect-timeout: 10
  read-timeout: 10
  write-timeout: 10

# OCR服务
ocr-server:
  endpoint: "http://localhost:8085"
  timeout: 1200

# 语义分割服务
semantic-splitter-server:
  endpoint: "http://localhost:8084"
  timeout: 1200

# mineru配置
mineru:
  # mineru服务端点
  endpoint: "http://localhost:8083"
  timeout: 1200
  # 缓存目录
  cache-dir: "/tmp/mineru_cache"

# TextIn (合合信息) 配置
textin:
  app-id: ""
  secret-code: ""
  api-url: "https://api.textin.com/ai/service/v1/pdf_to_markdown"
  timeout: 60
  cache-dir: "/tmp/textin_cache"

# 网页配置
web-config:
  # 浏览器相关配置
  browser:
    # 标题
    title: "智能应用开发"
    # 图标
    favicon: "./assets/images/logo.png"
    # 加载图标
    loading-icon: "./assets/images/loading-icon.png"
  # 应用配置
  app:
    # 应用左上角logo
    logo: ""
    # 应用左上角名称
    name: "智能体平台"
    # 登录页背景图
    login-banner: "./assets/images/login-banner.png"
    # 登录标题
    login-title: "👏欢迎登录智能体平台"
    # 默认首页: "/wk" 、"/console"
    default-home-page: "/wk"
    # 默认租户
    default-tenant-id: ${tenant.default-tenant-id}
    # 默认项目空间
    default-workspace-id: ${tenant.default-workspace-id}
    # 默认服务器知识库目录
    default-dataset-path: ${tenant.default-dataset-path}
  # 文档地址
  document:
    version: "2.0.0"
    url: ""
  tenant:
    # 租户请求头名称
    request-header: ${tenant.request-header}
  # 认证类型
  authentication:
    type: ${security.authentication.provider.type} # local, keycloak, oauth2
  encryption:
    pub-key: ${encryption.instance.1.pub-key}
  experiments:
    # 是否开启并行分支连线
    parallel-branch: true
    # 是否开启知识库 - 知识图谱功能
    knowledge-graph: true
    # 是否开启知识库 - 精准解析功能
    precise-parsing: true
    # 是否开启插件市场
    plugin-market: true
    # 是否开启在线文件预览
    online-file-preview: true
    # 是否开启反馈链
    feedback-chain: false
    # 是否开启智能体前端交互工具
    agent-frontend-tool: false
  # 是否显示错误信息
  show-errors: false
  # 知识库文件最大上传大小
  knowledge-max-file-size: 52428800
  settings:
    # 人员选择器模式(org-tree,user-list)
    personnel-picker-mode: ""
