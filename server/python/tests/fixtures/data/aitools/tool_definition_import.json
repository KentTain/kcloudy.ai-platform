    {
      "function_code": "get_license_info_license_info_get",
      "function_name": "获取License信息",
      "function_url": "/license/info",
      "function_method": "GET",
      "function_description": "获取当前License信息和状态\n\nReturns:\n    ORJSONResponse: 包含License详细信息的响应\n        - license_available: License是否可用\n        - status: License状态\n        - customer: 客户名称\n        - license_key: License密钥\n        - valid_until: 有效期截止时间\n        - days_remaining: 剩余天数\n        - features: 功能特性信息\n        - runtime_info: 运行时信息（仅当License有效时）",
      "status": "1",
      "parameters": [],
      "groupId": "tool_1",
      "groupName": "内置"
    },
    {
      "function_code": "reload_license_license_reload_post",
      "function_name": "重新加载License文件",
      "function_url": "/license/reload",
      "function_method": "POST",
      "function_description": "强制从磁盘重新加载License文件\n\n用于在更新License文件后重新验证，无需重启服务\n\nReturns:\n    ORJSONResponse: License重新加载结果\n        - success: 是否成功\n        - message: 操作消息\n        - customer: 客户名称\n        - license_key: License密钥\n        - status: License状态\n        - validated_at: 验证时间\n\nRaises:\n    HTTPException: 当License管理器不可用或重新加载失败时抛出",
      "status": "1",
      "parameters": [],
      "groupId": "tool_1",
      "groupName": "内置"
    },
