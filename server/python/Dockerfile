# Multi-module Dockerfile for Python Backend
# Supports BUILD_MODULES and APP_ROLE build arguments
# Uses Alibaba Cloud mirror for faster pulls in China
# Build context: server/ (parent of python/)

# =============================================================================
# Builder Stage - Install dependencies and prepare application
# =============================================================================
FROM registry.cn-zhangjiakou.aliyuncs.com/kcloudy-images/uv:python3.12-bookworm-slim AS builder

# Build arguments for metadata
ARG BUILD_MODULES=demo,iam,tenant
ARG APP_ROLE=web
ARG VERSION=latest

# Add uv to PATH (installed at /root/.local/bin/)
ENV PATH="/root/.local/bin:${PATH}"

# Set working directory
WORKDIR /app

# Copy dependency files first for better cache
COPY python/pyproject.toml python/uv.lock* ./

# Install dependencies with bytecode compilation for faster startup
# --compile-bytecode: Pre-compile Python source files to bytecode
# --no-dev: Skip development dependencies
# --frozen: Use exact versions from lock file
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --compile-bytecode --index-url https://mirrors.aliyun.com/pypi/simple/

# Copy source code
COPY python/src/ ./src/
COPY python/scripts/ ./scripts/
COPY python/manage.py ./
COPY python/alembic.ini ./

# Copy config files (shared across modules)
COPY config/ ./config/

# Generate modules config file
RUN mkdir -p src/config && \
    echo "# Auto-generated by Docker build" > src/config/modules.py && \
    echo "# BUILD_MODULES: ${BUILD_MODULES}" >> src/config/modules.py && \
    echo "ENABLED_MODULES = [\"$(echo ${BUILD_MODULES} | sed 's/,/\", \"/g')\"]" >> src/config/modules.py

# =============================================================================
# Production Stage - Minimal runtime image
# =============================================================================
FROM registry.cn-zhangjiakou.aliyuncs.com/kcloudy-images/python:3.12-slim-bookworm

# Build arguments for labels
ARG BUILD_MODULES=demo,iam,tenant
ARG APP_ROLE=web
ARG VERSION=latest
ARG BUILD_DATE
ARG GIT_REVISION

# Labels following OCI Image Spec
LABEL org.opencontainers.image.title="kcloudy-ai-platform-python" \
      org.opencontainers.image.description="AI Platform Python Backend - Modules: ${BUILD_MODULES}, Role: ${APP_ROLE}" \
      org.opencontainers.image.version=${VERSION} \
      org.opencontainers.image.created=${BUILD_DATE} \
      org.opencontainers.image.revision=${GIT_REVISION} \
      org.opencontainers.image.vendor="KCloudy" \
      org.opencontainers.image.authors="tianchangjun@outlook.com" \
      maintainer="tianchangjun@outlook.com" \
      build_modules=${BUILD_MODULES} \
      app_role=${APP_ROLE}

# Install system dependencies in single layer
# git: Required for version info and repository operations
# curl: Required for health checks
RUN sed -i 's|http://deb.debian.org/debian|https://mirrors.aliyun.com/debian|g; s|http://security.debian.org/debian-security|https://mirrors.aliyun.com/debian-security|g' /etc/apt/sources.list.d/debian.sources && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        curl=7.88.1-* \
        git=1:2.39.* \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Create non-root user with home directory
RUN groupadd --gid 1000 appgroup && \
    useradd --uid 1000 --gid appgroup --shell /bin/bash --create-home appuser

# Set working directory
WORKDIR /app

# Set environment variables in single layer to reduce image size
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app/src \
    PATH="/app/.venv/bin:${PATH}" \
    APP_CONFIG_DIR=/app/config

# Copy virtual environment and source code from builder with correct ownership
COPY --from=builder --chown=appuser:appgroup /app /app

# Copy and setup entrypoint script in single layer
COPY --chown=appuser:appgroup python/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Switch to non-root user for security
USER appuser

# Expose application port
EXPOSE 8080

# Health check with reasonable defaults
# --interval: Check every 30 seconds
# --timeout: Wait max 10 seconds for response
# --start-period: Wait 40 seconds for container startup (app initialization)
# --retries: Mark unhealthy after 3 consecutive failures
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl --fail http://localhost:8080/health || exit 1

# Entrypoint script handles APP_ROLE-based startup
ENTRYPOINT ["docker-entrypoint.sh"]
