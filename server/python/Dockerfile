# Multi-module Dockerfile for Python Backend
# Supports BUILD_MODULES and APP_ROLE build arguments
# Uses Alibaba Cloud mirror for faster pulls in China
# Build context: server/ (parent of python/)

# Builder stage - use image with uv pre-installed
FROM registry.cn-zhangjiakou.aliyuncs.com/kcloudy-images/uv:python3.12-bookworm-slim AS builder

# Add uv to PATH (installed at /root/.local/bin/)
ENV PATH="/root/.local/bin:${PATH}"

# Set working directory
WORKDIR /app

# Copy dependency files first for better cache
COPY python/pyproject.toml python/uv.lock* ./

# Install dependencies (uv is already installed in the base image)
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --index-url https://mirrors.aliyun.com/pypi/simple/

# Copy source code
COPY python/src/ ./src/
COPY python/scripts/ ./scripts/
COPY python/manage.py ./
COPY python/alembic.ini ./

# Copy config files (shared across modules)
COPY config/ ./config/

# Build argument: comma-separated module names (default: all modules)
# Example: BUILD_MODULES=demo,iam,tenant (platform version)
# Example: BUILD_MODULES=demo (demo module only)
ARG BUILD_MODULES=demo,iam,tenant

# Build argument: application role (web/task/listener)
ARG APP_ROLE=web

# Generate modules config file
RUN mkdir -p src/config && \
    echo "# Auto-generated by Docker build" > src/config/modules.py && \
    echo "# BUILD_MODULES: ${BUILD_MODULES}" >> src/config/modules.py && \
    echo "ENABLED_MODULES = [\"$(echo ${BUILD_MODULES} | sed 's/,/\", \"/g')\"]" >> src/config/modules.py

# Production stage
FROM registry.cn-zhangjiakou.aliyuncs.com/kcloudy-images/python:3.12-slim-bookworm

# Install system dependencies
RUN sed -i 's|http://deb.debian.org/debian|https://mirrors.aliyun.com/debian|g; s|http://security.debian.org/debian-security|https://mirrors.aliyun.com/debian-security|g' /etc/apt/sources.list.d/debian.sources && \
    apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -u 1000 appuser

# Set working directory
WORKDIR /app

# Set environment variables for production stage
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONPATH=/app/src
ENV PATH="/app/.venv/bin:${PATH}"
# Config folder path (in-container)
ENV APP_CONFIG_DIR=/app/config

# Copy virtual environment and source code from builder
COPY --from=builder --chown=appuser:appuser /app /app

# Copy entrypoint script
COPY python/docker-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Switch to non-root user
USER appuser

# Expose port
EXPOSE 8080

# Build metadata labels
ARG BUILD_MODULES=demo,iam,tenant
ARG APP_ROLE=web
ARG VERSION=latest
LABEL maintainer="tianchangjun@outlook.com"
LABEL version=${VERSION}
LABEL build_modules=${BUILD_MODULES}
LABEL app_role=${APP_ROLE}

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD curl -f http://localhost:8080/health || exit 1

# Entrypoint
ENTRYPOINT ["docker-entrypoint.sh"]