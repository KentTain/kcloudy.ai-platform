# Demo 本地开发配置示例
# 复制此文件为 application-local.yml 并修改配置

# 服务器配置
server:
  host: 0.0.0.0
  port: 8000
  debug: true

# 日志配置
logging:
  level: DEBUG

# 数据库配置
sqlalchemy:
  database_url: postgresql+asyncpg://postgres:postgres@localhost:5432/demo
  echo: true

# Redis 配置
redis:
  url: redis://localhost:6379/0
