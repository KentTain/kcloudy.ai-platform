# 本地开发配置示例
# 复制此文件为 application-local.yml 并修改配置

# 应用名称
name: demo-local

# 服务器配置
server:
  host: 127.0.0.1
  port: 8000
  debug: true
  timeout: 60
  body_limit: 52428800  # 50MB

# 日志配置
logging:
  level: DEBUG
  format: "{time:YYYY-MM-DD HH:mm:ss} | {level} | {name}:{function}:{line} | {message}"
  file: logs/app.log

# 数据库配置
database:
  url: postgresql://postgres:postgres@localhost:5432/demo_dev
  max_connections: 5
  min_connections: 1
  connect_timeout: 30
  idle_timeout: 300
  echo: true  # 打印 SQL

# Redis 配置
redis:
  url: redis://localhost:6379/1
  pool_size: 5
  timeout_ms: 10000

# AI 配置
ai:
  openai_api_key: "your-api-key-here"
  openai_base_url: "https://api.openai.com/v1"
  default_model: gpt-4o-mini
  embedding_model: text-embedding-3-small
