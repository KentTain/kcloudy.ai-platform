{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "PROXY_MANAGED",
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:15721",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "qianfan-code-latest",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "qianfan-code-latest",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "qianfan-code-latest",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Read(//tmp/**)",
      "Bash(cat*)",
      "Bash(cp*)",
      "Bash(curl*)",
      "Bash(echo \"Exit code: $?\")",
      "Bash(ls*)",
      "Bash(mkdir*)",
      "Bash(mv*)",
      "Bash(powershell *)",
      "Bash(cmd //c \"mklink /J config ..\\\\\\\\config\")",
      "Bash(ln -s ../config config)",
      "Bash(git *)",
      "Bash(gh api *)",
      "Bash(rtk *)",
      "Bash(openspec *)",
      "Bash(npm view *)",
      "Bash(npx shadcn-vue@latest add *)",
      "Bash(npx shadcn-vue@latest init --yes --defaults)",
      "Bash(pnpm *)",
      "Bash(python *)",
      "Bash(uv run*)",
      "Bash(uv sync*)",
      "Bash(cargo check *)",
      "Bash(cargo test *)",
      "Bash(rustup toolchain *)",
      "Bash(uv pip *)",
      "Bash(uv add *)",
      "Bash([ -f \"openspec/specs/$cap/spec.md\" ])",
      "mcp__codegraph__codegraph_*",
      "mcp__codegraph__codegraph_node",
      "mcp__codegraph__codegraph_files",
      "mcp__codegraph__codegraph_context"
    ]
  }
}
